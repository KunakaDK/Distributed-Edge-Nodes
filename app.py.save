            title=dict(text="Latence comparée (ms) — log scale", font=dict(size=11, color="#E8EDF5"), x=0),
            xaxis=dict(gridcolor="#1E2A45", tickfont=dict(size=10, color="#64748B")),
            yaxis=dict(type="log", gridcolor="#1E2A45", tickfont=dict(size=10)),
            showlegend=False,
            bargap=0.4,
        )
        st.plotly_chart(fig_bar, use_container_width=True, config={"displayModeBar": False})

