st.markdown('<div class="section-label">03 — Historique des Capteurs (Base de Données Cloud)</div>', unsafe_allow_html=True)

if not df.empty:
    # Température (full width avec seuil)
    st.plotly_chart(
        line_chart(df, "temperature", "Température (°C)", "#FF6B35", "°C",
                   threshold=30, threshold_label="Seuil alerte 30°C"),
        use_container_width=True, config={"displayModeBar": False})

    # 2 colonnes
    c1, c2 = st.columns(2)
    with c1:
        st.plotly_chart(line_chart(df, "humidity", "Humidité (%)", "#00D4FF", "%"),
                        use_container_width=True, config={"displayModeBar": False})
    with c2:
        st.plotly_chart(line_chart(df, "pressure", "Pression (hPa)", "#7C3AED", "hPa",
                                   threshold=950, threshold_label="Min 950 hPa"),
                        use_container_width=True, config={"displayModeBar": False})

    c3, c4 = st.columns(2)
    with c3:
        st.plotly_chart(line_chart(df, "voltage", "Tension (V)", "#FFD60A", "V",
                                   threshold=2.5, threshold_label="Min 2.5V"),
                        use_container_width=True, config={"displayModeBar": False})
    with c4:
        st.plotly_chart(line_chart(df, "current", "Courant (A)", "#00E5A0", "A"),
                        use_container_width=True, config={"displayModeBar": False})

    # Accélération (3 axes sur le même graphique)
    if "acceleration" in df.columns and isinstance(df["acceleration"].iloc[0], dict):
        df["acc_x"] = df["acceleration"].apply(lambda d: d.get("x", 0))
        df["acc_y"] = df["acceleration"].apply(lambda d: d.get("y", 0))
        df["acc_z"] = df["acceleration"].apply(lambda d: d.get("z", 0))

    if "acc_x" in df.columns:
        fig_acc = go.Figure()
        for axis, color in [("acc_x","#FF3B5C"), ("acc_y","#00D4FF"), ("acc_z","#7C3AED")]:
            fig_acc.add_trace(go.Scatter(
                x=df["timestamp"], y=df[axis],
                mode="lines", name=f"Axe {axis[-1].upper()}",
                line=dict(color=color, width=1.8),
                hovertemplate=f"<b>%{{y:.3f}} m/s²</b><extra>Axe {axis[-1].upper()}</extra>",
            ))
        fig_acc.update_layout(**PLOT_LAYOUT,
            title=dict(text="Accélération (m/s²) — 3 axes", font=dict(size=12, color="#E8EDF5"), x=0))
        fig_acc.update_xaxis(tickformat="%H:%M")
        st.plotly_chart(fig_acc, use_container_width=True, config={"displayModeBar": False})

