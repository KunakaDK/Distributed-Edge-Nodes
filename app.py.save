# ── Data fetchers ──────────────────────────────────────────────────────────────
@st.cache_data(ttl=20)
def fetch_cloud_data(limit=300):
    try:
        r = requests.get(f"{API_URL}/data", params={"limit": limit}, headers=HEADERS, timeout=10)
        r.raise_for_status()
        df = pd.DataFrame(r.json())
        if not df.empty:
            df["timestamp"] = pd.to_datetime(df["timestamp"])
            df = df.sort_values("timestamp").reset_index(drop=True)
        return df, None
    except Exception as e:
        return pd.DataFrame(), str(e)

@st.cache_data(ttl=20)
def fetch_alerts(limit=20):
    try:
        r = requests.get(f"{MICRO_B}/alertes", params={"limit": limit}, timeout=4)
        return r.json().get("alertes", [])
    except:
        return []

@st.cache_data(ttl=20)
def fetch_b_health():
    try:
        r = requests.get(f"{MICRO_B}/health", timeout=3)
        return r.json()
    except:
        return None

def measure_cloud_latency():
    try:
        t0 = time.time()
        requests.get(f"{API_URL}/health", timeout=10)
        return (time.time() - t0) * 1000
    except:
        return None

# ── Plotly theme ───────────────────────────────────────────────────────────────
PLOT_LAYOUT = dict(
    paper_bgcolor="rgba(0,0,0,0)",
    plot_bgcolor="rgba(0,0,0,0)",
    font=dict(family="DM Sans", color="#64748B", size=11),
    margin=dict(l=0, r=10, t=30, b=0),
    xaxis=dict(
        gridcolor="#1E2A45", showgrid=True, zeroline=False,
        tickfont=dict(size=10, color="#64748B"),
    ),
    yaxis=dict(
        gridcolor="#1E2A45", showgrid=True, zeroline=False,
        tickfont=dict(size=10, color="#64748B"),
    ),
    legend=dict(bgcolor="rgba(0,0,0,0)", font=dict(size=10)),
    hovermode="x unified",
)

def line_chart(df, y, title, color, unit="", threshold=None, threshold_label=""):
    fig = go.Figure()
    fig.add_trace(go.Scatter(
        x=df["timestamp"], y=df[y],
        mode="lines+markers",
        line=dict(color=color, width=2),
        marker=dict(size=4, color=color),
        fill="tozeroy",
        fillcolor=color.replace(")", ",0.06)").replace("rgb", "rgba") if "rgb" in color else color + "10",
        name=title,
        hovertemplate=f"<b>%{{y:.2f}} {unit}</b><br>%{{x|%H:%M:%S}}<extra></extra>",
    ))
    if threshold is not None:
        fig.add_hline(y=threshold, line_dash="dash", line_color="#FF3B5C",
                      line_width=1.5, opacity=0.7,
                      annotation_text=threshold_label,
                      annotation_font=dict(size=9, color="#FF3B5C"))
    fig.update_layout(**PLOT_LAYOUT, title=dict(
        text=title, font=dict(size=12, color="#E8EDF5"), x=0, pad=dict(l=0)))
    fig.update_xaxis(showgrid=True, tickformat="%H:%M")
    return fig

