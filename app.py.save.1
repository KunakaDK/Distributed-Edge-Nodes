# ── Mesures de latence (sans cache — toujours fraîches) ───────────────────────
def measure_edge_latency(n=5):
    """Mesure aller-retour vers Microservice B (moyenne de n essais)."""
    latencies = []
    for _ in range(n):
        try:
            t0 = time.time()
            requests.get(f"{MICRO_B}/health", timeout=5)
            latencies.append((time.time() - t0) * 1000)
            time.sleep(0.05)
        except Exception:
            pass
    return sum(latencies) / len(latencies) if latencies else None

def measure_cloud_latency(n=5):
    """Mesure aller-retour vers l'API Azure (moyenne de n essais)."""
    latencies = []
    for _ in range(n):
        try:
            t0 = time.time()
            requests.get(f"{API_URL}/health", timeout=10)
            latencies.append((time.time() - t0) * 1000)
            time.sleep(0.1)
        except Exception:
            pass
    return sum(latencies) / len(latencies) if latencies else None

# ── Data fetchers (avec cache 20s) ────────────────────────────────────────────
@st.cache_data(ttl=20)
def fetch_cloud_data(limit=300):
    try:
        r = requests.get(f"{API_URL}/data", params={"limit": limit},
                         headers=HEADERS, timeout=10)
        r.raise_for_status()
        df = pd.DataFrame(r.json())
        if not df.empty:
            df["timestamp"] = pd.to_datetime(df["timestamp"])
            df = df.sort_values("timestamp").reset_index(drop=True)
        return df, None
    except Exception as e:
        return pd.DataFrame(), str(e)

@st.cache_data(ttl=20)
def fetch_alerts(limit=20):
    try:
        r = requests.get(f"{MICRO_B}/alertes", params={"limit": limit}, timeout=4)
        return r.json().get("alertes", [])
    except Exception:
        return []

@st.cache_data(ttl=20)
def fetch_b_health():
    try:
        r = requests.get(f"{MICRO_B}/health", timeout=3)
        return r.json()
    except Exception:
        return None

@st.cache_data(ttl=20)
def fetch_cloud_health():
    try:
        r = requests.get(f"{API_URL}/health", timeout=5)
        return r.json()
    except Exception:
        return None

