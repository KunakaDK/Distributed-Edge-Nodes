def line_chart(df, y, title, color, unit="", threshold=None, threshold_label=""):
    fig = go.Figure()
    fig.add_trace(go.Scatter(
        x=df["timestamp"], y=df[y],
        mode="lines+markers",
        line=dict(color=color, width=2),
        marker=dict(size=4, color=color),
        fill="tozeroy", fillcolor=color + "18",
        name=title,
        hovertemplate=f"<b>%{{y:.2f}} {unit}</b><br>%{{x|%H:%M:%S}}<extra></extra>",
    ))
    if threshold is not None:
        fig.add_hline(y=threshold, line_dash="dash", line_color="#FF3B5C",
                      line_width=1.5, opacity=0.7,
                      annotation_text=threshold_label,
                      annotation_font=dict(size=9, color="#FF3B5C"))
    fig.update_layout(**BASE_LAYOUT,
        title=dict(text=title, font=dict(size=12, color="#E8EDF5"), x=0))
    fig.update_xaxis(tickformat="%H:%M")
    return fig

